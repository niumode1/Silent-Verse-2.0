; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="SilentVerse"
config/description="无言史诗 — 第一人称 3D 硬核生存轮回 MMO。现实物理化学参数驱动的世界。"
config/version="0.1.0"
config/tags=PackedStringArray("mmo", "survival", "simulation", "physics")
run/main_scene="res://scenes/client_3d.tscn"
config/features=PackedStringArray("4.6")
config/icon="res://assets/icon.svg"

[autoload]

PhysicsConstants="*res://scripts/shared/physics/physics_constants.gd"
MaterialDB="*res://scripts/shared/physics/material_database.gd"
ReactionRegistry="*res://scripts/shared/physics/reaction_system.gd"

[debug]

gdscript/warnings/treat_warnings_as_errors=false

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/size/mode=2

[dotnet]

project/assembly_name="SilentVerse"

[editor_plugins]

enabled=PackedStringArray("res://addons/copy_all_errors/plugin.cfg")

[input]

